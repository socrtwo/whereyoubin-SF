# Pretty URLs + front controller for Apache deployments.
RewriteEngine On

# If the requested file exists, serve it directly; otherwise hand off to index.php.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [L]

# Service workers need a wide scope header
<Files "sw.js">
    Header set Service-Worker-Allowed "/"
    Header set Cache-Control "no-cache"
</Files>

# Cache static assets
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|webp|woff2?)$">
    Header set Cache-Control "public, max-age=86400"
</FilesMatch>
